# Required: Gateway authentication token (generate a long random string)
OPENCLAW_GATEWAY_TOKEN=

# Cloud AI Providers (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=

# Optional: Messaging integrations
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# Port (Railway sets this automatically)
PORT=18789
